# Scegli provider: mock | imap-smtp | gmail | outlook
EMAIL_PROVIDER=mock

# Config comuni
EMAIL_DEFAULT_FROM=no-reply@example.com

# IMAP/SMTP (provider: imap-smtp)
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Gmail API (provider: gmail)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Microsoft Graph (provider: outlook)
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_USER_ID=
